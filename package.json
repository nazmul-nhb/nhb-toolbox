{
  "name": "nhb-toolbox-monorepo",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --recursive build",
    "test": "pnpm --filter nhb-toolbox test",
    "lint": "biome lint --diagnostic-level=error",
    "fix": "biome check --write --diagnostic-level=error",
    "format": "biome format --write --diagnostic-level=error",
    "commit": "nhb-commit",
    "module": "nhb-module",
    "plugin": "nhb-module -t chronos-plugin -d packages/nhb-toolbox/src/date/plugins",
    "count": "nhb-count",
    "delete": "nhb-delete"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nhb-scripts": "^1.9.2"
  },
  "lint-staged": {
    "*.+((c|m)?js(x)?|(c|m)?ts(x)?)": [
      "biome format --write --diagnostic-level=error",
      "biome lint --diagnostic-level=error"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "version": "4.30.1"
}
