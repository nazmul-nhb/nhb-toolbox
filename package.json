{
	"name": "nhb-toolbox-monorepo",
	"private": true,
	"scripts": {
		"prepare": "husky",
		"build": "pnpm --recursive build",
		"test": "pnpm --filter nhb-toolbox test",
		"lint": "biome lint --diagnostic-level=error",
		"fix": "biome check --write --diagnostic-level=error",
		"format": "biome format --write --diagnostic-level=error",
		"commit": "nhb-commit",
		"module": "nhb-module",
		"plugin": "nhb-module -t chronos-plugin -d packages/nhb-toolbox/src/date/plugins",
		"count": "nhb-count",
		"delete": "nhb-delete"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@changesets/cli": "^2.31.0",
		"@nhb-toolbox/chronos": "file:packages/chronos/nhb-toolbox-chronos-4.30.1.tgz",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"nhb-scripts": "^1.9.2"
	},
	"lint-staged": {
		"*.+((c|m)?js(x)?|(c|m)?ts(x)?)": [
			"biome format --write --diagnostic-level=error",
			"biome lint --diagnostic-level=error"
		]
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
	"version": "4.30.1"
}
